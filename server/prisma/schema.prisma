// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Barber {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  role         String
  status       String        @default("Ativo")
  permissions  Json
  foto_perfil  String?
  appointments Appointment[]
  productSales ProductSale[]
  shifts       WorkingShifts[]
  deletedAt    DateTime?

  @@index([deletedAt])
}

model Service {
  id       Int    @id @default(autoincrement())
  name     String
  price    Float
  duration String
}

model Customer {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  phone        String
  appointments Appointment[]
  createdAt    DateTime      @default(now())
}

model Appointment {
  id         Int       @id @default(autoincrement())
  customer   String
  phone      String?
  service    String
  barberId   Int
  barber     Barber    @relation(fields: [barberId], references: [id])
  customerId Int?      @map("customer_id")
  client     Customer? @relation(fields: [customerId], references: [id])
  date       String
  time       String
  status     String    @default("Agendado")
  price      Float
  payments   Json?

  @@index([date])
  @@index([status])
  @@index([barberId])
  @@index([customerId])
}

model Product {
  id       Int    @id @default(autoincrement())
  name     String
  price    Float
  cost     Float
  stock    Int
  category String
}

model ProductSale {
  id          Int     @id @default(autoincrement())
  productId   Int
  productName String
  price       Float
  cost        Float
  quantity    Int
  date        String
  barberId    Int?
  barber      Barber? @relation(fields: [barberId], references: [id])

  @@index([date])
  @@index([barberId])
}

model BusinessInfo {
  id       Int     @id @default(1)
  name     String
  phone    String
  email    String
  address  String
  logo_url String?
}

model Expense {
  id          Int     @id @default(autoincrement())
  description String
  amount      Float
  date        String
  category    String?
}

model WorkingHours {
  dia_semana      Int     @id
  is_aberto       Boolean @default(true)
  hora_abertura   String
  hora_fechamento String
  almoco_inicio   String?
  almoco_fim      String?

  @@map("horarios_funcionamento")
}

model Holiday {
  id        Int    @id @default(autoincrement())
  data      String @unique
  descricao String

  @@map("feriados")
}

model WorkingShifts {
  id_barbeiro Int
  barber      Barber  @relation(fields: [id_barbeiro], references: [id], onDelete: Cascade)
  dia_semana  Int
  hora_inicio String
  hora_fim    String
  ativo       Boolean @default(true)

  @@id([id_barbeiro, dia_semana, hora_inicio])
  @@map("horarios_trabalho")
} 

