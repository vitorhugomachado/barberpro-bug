// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Barber {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  role         String
  status       String        @default("Ativo")
  permissions  Json
  appointments Appointment[]
  productSales ProductSale[]
}

model Service {
  id       Int    @id @default(autoincrement())
  name     String
  price    Float
  duration String
}

model Appointment {
  id       Int     @id @default(autoincrement())
  customer String
  phone    String?
  service  String
  barberId Int
  barber   Barber  @relation(fields: [barberId], references: [id])
  date     String
  time     String
  status   String  @default("Agendado")
  price    Float
  payments Json?
}

model Product {
  id       Int    @id @default(autoincrement())
  name     String
  price    Float
  cost     Float
  stock    Int
  category String
}

model ProductSale {
  id          Int     @id @default(autoincrement())
  productId   Int
  productName String
  price       Float
  cost        Float
  quantity    Int
  date        String
  barberId    Int?
  barber      Barber? @relation(fields: [barberId], references: [id])
}

model BusinessInfo {
  id      Int    @id @default(1)
  name    String
  phone   String
  email   String
  address String
}

model Expense {
  id          Int     @id @default(autoincrement())
  description String
  amount      Float
  date        String
  category    String?
}
